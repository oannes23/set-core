{
  "name": "set-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Set-based skill minigame — the action-resolution layer of a web RPG. Framework-free; Vite + Vitest + TypeScript.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:schema": "ts-json-schema-generator --path src/data/schema.ts --type GameData --tsconfig tsconfig.json --out src/data/content/schema.json --no-type-check"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "ajv": "^8.20.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
