# Vite build-time environment (committed defaults; see src/net/config.ts + src/vite-env.d.ts).
# VITE_-prefixed vars are baked into the client bundle and are PUBLIC — never put secrets here.
# Personal/local overrides go in .env.local (gitignored), e.g. to point at a local backend in dev:
#   VITE_EMBASSY_URL=http://127.0.0.1:8000

# Default Embassy instance the client talks to. "For now" this is the alpha service on bob — LAN-only,
# plain HTTP. It resolves and works from a LAN, http-served client; an https page can't call it
# (mixed content). The player can always override it per-device in Embassy → Registry. Swap this to the
# public HTTPS URL (e.g. https://api.braewood.tv) once the VPS front is up.
VITE_EMBASSY_URL=http://bob.lan:5230
